{
  "manifest_version": 3,
  "name": "Website Time Tracker",
  "version": "0.1.0",
  "description": "Show today's usage time for the current site on the top-right corner.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "サイト利用ランキング",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
